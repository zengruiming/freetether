<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>items</key>
    <array>

        <!-- Master Switch -->
        <dict>
            <key>cell</key><string>PSGroupCell</string>
            <key>label</key><string>MASTER_CONTROL</string>
        </dict>

        <dict>
            <key>cell</key><string>PSSwitchCell</string>
            <key>default</key><true/>
            <key>key</key><string>enabled</string>
            <key>label</key><string>ENABLED</string>
            <key>PostNotification</key><string>com.freetether.prefschanged</string>
        </dict>

        <!-- Personal Hotspot shortcut -->
        <dict>
            <key>cell</key><string>PSGroupCell</string>
            <key>label</key><string>PERSONAL_HOTSPOT</string>
            <key>footerText</key><string>PERSONAL_HOTSPOT_FOOTER</string>
        </dict>

        <dict>
            <key>cell</key><string>PSButtonCell</string>
            <key>label</key><string>OPEN_HOTSPOT_SETTINGS</string>
            <key>action</key><string>openPersonalHotspot</string>
        </dict>

        <!-- VPN/Wi-Fi Sharing Section -->
        <dict>
            <key>cell</key><string>PSGroupCell</string>
            <key>label</key><string>SHARING</string>
            <key>footerText</key><string>SHARING_FOOTER</string>
        </dict>

        <dict>
            <key>cell</key><string>PSSwitchCell</string>
            <key>default</key><false/>
            <key>key</key><string>vpnSharing</string>
            <key>label</key><string>VPN_SHARING</string>
            <key>PostNotification</key><string>com.freetether.prefschanged</string>
        </dict>

        <dict>
            <key>cell</key><string>PSSwitchCell</string>
            <key>default</key><false/>
            <key>key</key><string>wifiSharing</string>
            <key>label</key><string>WIFI_SHARING</string>
            <key>PostNotification</key><string>com.freetether.prefschanged</string>
        </dict>

        <!-- Advanced Section -->
        <dict>
            <key>cell</key><string>PSGroupCell</string>
            <key>label</key><string>ADVANCED</string>
        </dict>

        <dict>
            <key>cell</key><string>PSSwitchCell</string>
            <key>default</key><false/>
            <key>key</key><string>debugLog</string>
            <key>label</key><string>DEBUG_LOG</string>
            <key>PostNotification</key><string>com.freetether.prefschanged</string>
        </dict>

        <!-- About Section -->
        <dict>
            <key>cell</key><string>PSGroupCell</string>
            <key>label</key><string>ABOUT</string>
            <key>footerText</key><string>ABOUT_FOOTER</string>
        </dict>

        <dict>
            <key>cell</key><string>PSButtonCell</string>
            <key>label</key><string>GITHUB</string>
            <key>action</key><string>openGitHub</string>
        </dict>

    </array>
    <key>title</key><string>FreeTether</string>
</dict>
</plist>
